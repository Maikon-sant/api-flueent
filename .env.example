# Flueet API - Environment Variables

# Application Settings
APP_NAME=Flueent API
APP_VERSION=1.0.0
DEBUG=True

# Database Configuration
# ====================
# Para desenvolvimento local, você pode usar SQLite:
# DATABASE_URL=sqlite:///./flueent.db

# Para produção, use PostgreSQL:
# DATABASE_URL=postgresql://username:password@host:port/database
# Exemplo:
# DATABASE_URL=postgresql://flueent_user:senha123@localhost:5432/flueent_db

# Para produção, use MySQL:
# DATABASE_URL=mysql+pymysql://username:password@host:port/database
# Exemplo:
# DATABASE_URL=mysql+pymysql://root:senha123@localhost:3306/flueent_db

# Exemplos de serviços em nuvem:
# PostgreSQL AWS RDS:
# DATABASE_URL=postgresql://user:password@aws-rds-endpoint:5432/flueent
# MySQL AWS RDS:
# DATABASE_URL=mysql+pymysql://admin:password@flueent-db.abc123.us-east-1.rds.amazonaws.com:3306/flueent
# MySQL PlanetScale:
# DATABASE_URL=mysql+pymysql://user:password@aws.connect.psdb.cloud/flueent?ssl_ca=/etc/ssl/cert.pem

DATABASE_URL=sqlite:///./flueent.db

# CORS Settings
# Lista de origens permitidas, separadas por vírgula
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# API Keys (se necessário no futuro)
# OPENAI_API_KEY=your-api-key-here
# ANTHROPIC_API_KEY=your-api-key-here
